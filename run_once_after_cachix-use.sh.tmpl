#!/bin/bash
# Bootstrap nix-community cachix so that emacs-overlay outputs are
# fetched as binaries instead of compiled from source.
#
# Runs once per machine (chezmoi run_once_*). On failure (e.g. sudo not
# available because chezmoi apply was run non-interactively), prints
# manual instructions and exits 0 so chezmoi apply continues.
# emacs-overlay just falls back to source builds — slow but functional.
#
# Lexically ordered before run_onchange_nix-apply.sh so that, when this
# succeeds, the cache is already in effect for the first home-manager
# switch.

set -uo pipefail

# Absolute path so sudo (which resets PATH) can still find nix.
NIX_BIN="/nix/var/nix/profiles/default/bin/nix"
CUSTOM_CONF="/etc/nix/nix.custom.conf"

# Idempotency: skip if already wired up.
if [ -f "$CUSTOM_CONF" ] && grep -q 'nix-community.cachix.org' "$CUSTOM_CONF"; then
    echo "nix-community cachix already configured. Skipping."
    exit 0
fi

print_manual() {
    cat <<EOF >&2

WARNING: nix-community cachix is not configured.

  Reason: cachix needs to write /etc/nix/nix.custom.conf as root, and
  this run does not have sudo available (chezmoi apply was likely run
  non-interactively, or sudo credentials are not cached).

  Without this cache, packages from emacs-overlay (emacs, emacs-pgtk,
  ...) will be compiled from source on the first home-manager switch.

  To enable it, run once:

    sudo $NIX_BIN run nixpkgs#cachix -- use nix-community

EOF
}

# If no cached sudo creds AND no tty, defer to manual.
if ! sudo -n true 2>/dev/null && [ ! -t 0 ]; then
    print_manual
    exit 0
fi

echo "Configuring nix-community cachix (sudo password may be required)..."
if ! sudo "$NIX_BIN" run nixpkgs#cachix -- use nix-community; then
    print_manual
    exit 0
fi

echo "Cachix configured."
