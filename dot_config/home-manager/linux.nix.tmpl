{ pkgs, inputs, config, ... }:

{
  imports = [
    inputs.xremap-flake.homeManagerModules.default
  ];

  home.homeDirectory = "{{ .chezmoi.homeDir }}";

  targets.genericLinux.enable = true;

  home.packages = [
    inputs.lsp-proxy.packages.${pkgs.system}.default
    inputs.xremap-flake.packages.${pkgs.system}.xremap-cosmic
    pkgs.cosmic-ext-applet-clipboard-manager
    # Rootless Docker CLI (compose + buildx included by default in nixpkgs;
    # override is explicit so upgrades never accidentally drop these features).
    (pkgs.docker.override { composeSupport = true; buildxSupport = true; })
  ];

  # Rootless Docker socket. The chezmoi run_once_after_docker-rootless-setup.sh
  # script provisions the user-level dockerd. Resolved at apply time so the
  # value is baked into the user profile and inherited by every login shell.
  home.sessionVariables = {
    DOCKER_HOST = "unix:///run/user/{{ output "id" "-u" | trim }}/docker.sock";
  };

  programs.emacs = {
    enable = true;
    # 30.2 の treesit.c は predicate を `#match` (?なし) で出力するが、
    # nixpkgs 同梱の tree-sitter v0.26+ は `?`/`!` で終わる述語名しか
    # 受け付けない。flake.nix の treeSitterOverlay で v0.25.10 に pin
    # して回避している。Emacs 31 系で treesit.c が `#match?` 化済みに
    # なるので、その時点で overlay と一緒にこのコメントも消す。
    package = pkgs.emacs-pgtk;            # stable (30.x) + native-comp + Wayland
    # package = pkgs.emacs-unstable-pgtk; # latest tag (e.g. 31 pretest) + pgtk
    # package = pkgs.emacs-git-pgtk;      # master HEAD + pgtk
    extraPackages = epkgs: [
      (epkgs.treesit-grammars.with-grammars (p: with p; [
        tree-sitter-bash
        tree-sitter-c
        tree-sitter-cpp
        tree-sitter-css
        tree-sitter-dockerfile
        tree-sitter-go
        tree-sitter-graphql
        tree-sitter-html
        tree-sitter-javascript
        tree-sitter-json
        tree-sitter-lua
        tree-sitter-markdown
        tree-sitter-markdown-inline
        tree-sitter-nix
        tree-sitter-python
        tree-sitter-ruby
        tree-sitter-rust
        tree-sitter-toml
        tree-sitter-tsx
        tree-sitter-typescript
        tree-sitter-yaml
      ]))
    ];
  };

  # The xremap-flake home-manager module is always user-mode (no serviceMode
  # option) and requires the YAML inline via `yamlConfig`; it cannot read an
  # external path via `extraArgs` (mkExecStart appends the module-generated
  # configFile last). To keep chezmoi as the single source of truth for the
  # xremap config we read the deployed file at evaluation time. Chezmoi places
  # regular dotfiles before run_onchange_nix-apply.sh runs, so this file
  # always exists when home-manager switches.
  services.xremap = {
    enable = true;
    withCosmic = true;
    yamlConfig = builtins.readFile "${config.home.homeDirectory}/.config/xremap/config.yml";
  };
}
