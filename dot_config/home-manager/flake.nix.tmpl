{
  description = "Home Manager configuration";

  inputs = {
    nixpkgs.url = "github:nixos/nixpkgs/nixpkgs-unstable";
    home-manager = {
      url = "github:nix-community/home-manager";
      inputs.nixpkgs.follows = "nixpkgs";
    };
    nix-claude-code.url = "github:ryoppippi/nix-claude-code";
    nix-darwin = {
      url = "github:LnL7/nix-darwin";
      inputs.nixpkgs.follows = "nixpkgs";
    };
    emacs-overlay = {
      url = "github:nix-community/emacs-overlay";
      inputs.nixpkgs.follows = "nixpkgs";
    };
    xremap-flake = {
      url = "github:xremap/nix-flake";
      inputs.nixpkgs.follows = "nixpkgs";
    };
    lsp-proxy = {
      url = "github:jadestrong/lsp-proxy";
      inputs.nixpkgs.follows = "nixpkgs";
    };
    nixos-cosmic = {
      url = "github:lilyinstarlight/nixos-cosmic";
      inputs.nixpkgs.follows = "nixpkgs";
    };
  };

  outputs = { self, nixpkgs, home-manager, nix-claude-code, nix-darwin, emacs-overlay, xremap-flake, lsp-proxy, nixos-cosmic, ... }@inputs:
    let
      direnvOverlay = final: prev: {
        direnv = prev.direnv.overrideAttrs (old: { doCheck = false; });
      };
      # tree-sitter v0.26 で query parser が strict 化され、predicate 名は
      # `?`/`!` で終わらないと TSQueryErrorSyntax を返すようになった
      # (tree-sitter/lib/src/query.c の ts_query__parse_predicate)。
      # 一方 Emacs 30.2 の treesit.c は今でも `#match`/`#equal` (?なし)
      # を出力するため、ruby-ts-mode 等の :match を含む font-lock クエリが
      # コンパイル時点で弾かれる。
      # Emacs master では `#match?` 化済みなので、Emacs 31 系が nixpkgs に
      # 入った時点でこの overlay は外す。
      treeSitterOverlay = final: prev: {
        tree-sitter = prev.tree-sitter.overrideAttrs (old: rec {
          version = "0.25.10";
          src = prev.fetchFromGitHub {
            owner = "tree-sitter";
            repo = "tree-sitter";
            tag = "v${version}";
            hash = "sha256-aHszbvLCLqCwAS4F4UmM3wbSb81QuG9FM7BDHTu1ZvM=";
            fetchSubmodules = true;
          };
          cargoDeps = prev.rustPlatform.fetchCargoVendor {
            inherit (old) pname;
            inherit version src;
            hash = "sha256-4R5Y9yancbg/w3PhACtsWq0+gieUd2j8YnmEj/5eqkg=";
          };
          # nixpkgs 側の "allow `-` in grammar names" patch は v0.26+ 専用
          # (該当コミットが v0.25.10 には含まれず、適用しても無害だが
          # 不要なので落とす)。
          patches = [];
        });
      };
      overlays = [
        direnvOverlay
        treeSitterOverlay
        nix-claude-code.overlays.default
        emacs-overlay.overlays.default
        nixos-cosmic.overlays.default
      ];
      config.allowUnfreePredicate = pkg:
        builtins.elem (nixpkgs.lib.getName pkg) [ "claude-code" ];
      mkPkgs = system: import nixpkgs { inherit system overlays config; };
    in {
    homeConfigurations = {
      "{{ .chezmoi.username }}@popos" = home-manager.lib.homeManagerConfiguration {
        pkgs = mkPkgs "x86_64-linux";
        modules = [ ./home.nix ./linux.nix ];
        extraSpecialArgs = { inherit inputs; };
      };
      "{{ .chezmoi.username }}@macos" = home-manager.lib.homeManagerConfiguration {
        pkgs = mkPkgs "aarch64-darwin";
        modules = [ ./home.nix ./darwin.nix ];
        extraSpecialArgs = { inherit inputs; };
      };
    };

    # nix-darwin manages macOS system settings (defaults, keyboard remap) and
    # Homebrew (taps/brews/casks). User-level config still lives in
    # home-manager via homeConfigurations above. Switch with:
    #   nix run nix-darwin -- switch --flake ~/.config/home-manager#{{ .chezmoi.hostname }}
    darwinConfigurations.{{ .chezmoi.hostname }} = nix-darwin.lib.darwinSystem {
      system = "aarch64-darwin";
      modules = [ ./nix-darwin ];
    };
  };
}
