{ pkgs, lib, config, ... }:

{
  # Nikon Z5 webcam pipeline (Approach A: gphoto2 + v4l2loopback + ffmpeg).
  #
  # Imported by linux.nix; Pop!_OS / Cosmic DE specific.
  #
  # The OS-layer pieces (v4l2loopback kernel module, /etc/modprobe.d
  # configuration, the 'camera' group) are provisioned by chezmoi's
  # run_once_after_nikon-webcam-setup.sh.tmpl. This module owns only the
  # user-scoped artifacts (binaries, smoke-test CLI, OBS Studio,
  # systemd user service) per spec §11.

  home.packages = with pkgs; [
    gphoto2
    ffmpeg
    v4l-utils

    (writeShellApplication {
      name = "nikon-webcam-smoketest";
      runtimeInputs = [ gphoto2 coreutils xxd ];
      text = ''
        # nikon-webcam-smoketest — verify gphoto2 viability before any
        # v4l2loopback usage. Three stages with distinct exit codes per
        # spec §3.1 / US-002.
        #
        # Exit codes:
        #   0  — all checks passed; Approach A is viable
        #   10 — gphoto2 --auto-detect did not match Nikon
        #   11 — still capture (--capture-image-and-download) failed
        #   12 — Live View (--capture-movie) failed (no MJPEG SOI / empty)

        still_path=/tmp/z5-test.jpg
        movie_path=/tmp/z5-test.mjpg

        cleanup() {
          rm -f "$still_path" "$movie_path"
        }
        trap cleanup EXIT

        # ---- 1/3: detect ----
        if ! gphoto2 --auto-detect 2>/dev/null | grep -qi nikon; then
          echo "[1/3] Detect: FAIL (no Nikon body found)" >&2
          echo "RESULT: gphoto2 cannot see the camera. Verify the USB cable and" >&2
          echo "        that the Z5 is powered on in MTP/PTP mode." >&2
          echo "        Recommended next: Approach C (HDMI capture dongle)" >&2
          echo "                          if that hardware is available." >&2
          exit 10
        fi
        nikon_line=$(gphoto2 --auto-detect 2>/dev/null | grep -i nikon | head -n 1)
        echo "[1/3] Detect: PASS ($nikon_line)"

        # ---- 2/3: still capture ----
        rm -f "$still_path"
        if ! gphoto2 \
            --capture-image-and-download \
            --filename "$still_path" \
            --force-overwrite >/dev/null 2>&1; then
          echo "[2/3] Still capture: FAIL" >&2
          echo "RESULT: still capture failed. Check udev rules and 'camera'" >&2
          echo "        group membership (re-login may be required)." >&2
          echo "        Stay on Approach A and retry after fixing." >&2
          exit 11
        fi
        if [ ! -s "$still_path" ]; then
          echo "[2/3] Still capture: FAIL (empty file)" >&2
          exit 11
        fi
        still_size=$(du -h "$still_path" | cut -f1)
        echo "[2/3] Still capture: PASS ($still_path, $still_size)"

        # ---- 3/3: live view ----
        rm -f "$movie_path"
        # `timeout 5` returns 124 when the timeout fires. We always inspect
        # the resulting file regardless of exit status, hence the `|| true`.
        timeout 5 gphoto2 --stdout --capture-movie > "$movie_path" 2>/dev/null || true

        if [ ! -s "$movie_path" ]; then
          echo "[3/3] Live View: FAIL (empty file)" >&2
          echo "RESULT: gphoto2 --capture-movie produced no data." >&2
          echo "        Recommended next: Approach B (mtplvcap) or" >&2
          echo "                          Approach C (HDMI capture)." >&2
          exit 12
        fi

        soi=$(head -c 3 "$movie_path" | xxd -p)
        if [ "$soi" != "ffd8ff" ]; then
          echo "[3/3] Live View: FAIL (no MJPEG SOI; first 3 bytes='$soi')" >&2
          echo "RESULT: stream is not MJPEG." >&2
          echo "        Recommended next: Approach B (mtplvcap) or" >&2
          echo "                          Approach C (HDMI capture)." >&2
          exit 12
        fi

        movie_size=$(du -h "$movie_path" | cut -f1)
        echo "[3/3] Live View: PASS ($movie_path, $movie_size, MJPEG SOI verified)"

        echo "RESULT: Approach A (gphoto2 + v4l2loopback) is viable."
      '';
    })
  ];

  programs.obs-studio = {
    enable = true;
    plugins = with pkgs.obs-studio-plugins; [
      obs-pipewire-audio-capture
      # NOTE: wlrobs intentionally NOT included — Cosmic uses cosmic-comp,
      # not wlroots, so wlrobs cannot capture from the compositor.
      # NOTE: obs-vaapi commented out by default; enable it only when GPU
      # hardware encoding is required (spec Q7).
    ];
  };

  systemd.user.services.nikon-webcam = {
    Unit = {
      Description = "Nikon Z5 Live View to v4l2loopback (/dev/video10)";
      After = [ "graphical-session.target" ];
      StartLimitBurst = 3;
      StartLimitIntervalSec = 60;
    };
    Service = {
      Type = "simple";
      ExecStartPre = "${pkgs.writeShellScript "nikon-webcam-precheck" ''
        # Pre-flight checks. `set -e` / pipefail are intentionally NOT
        # enabled: a failing `grep -qi` on a pipe must reach the actionable
        # error branch (US-003 AC-002), not silently abort the script.
        if ! test -e /dev/video10; then
          echo "ERROR: /dev/video10 not found. Is v4l2loopback loaded?" >&2
          echo "       Try: sudo modprobe v4l2loopback" >&2
          exit 1
        fi
        if ! ${pkgs.gphoto2}/bin/gphoto2 --auto-detect | ${pkgs.gnugrep}/bin/grep -qi nikon; then
          echo "ERROR: Nikon camera not detected via gphoto2." >&2
          echo "       Check USB cable, MTP/PTP mode, and 'camera' group membership." >&2
          exit 1
        fi
      ''}";
      ExecStart = "${pkgs.writeShellScript "nikon-webcam-pipeline" ''
        exec ${pkgs.gphoto2}/bin/gphoto2 --stdout --capture-movie \
          | ${pkgs.ffmpeg}/bin/ffmpeg -i - \
              -vcodec rawvideo -pix_fmt yuv420p -threads 0 \
              -f v4l2 /dev/video10
      ''}";
      Restart = "on-failure";
      RestartSec = 5;
    };
    # No [Install] section: the unit is "linked" / "static", not enabled.
    # Users opt in per session via `systemctl --user start nikon-webcam`
    # (spec US-003 AC-004).
  };
}
